digraph s3_layout {
    rankdir=TB
    bgcolor="white"
    node [fontname="Courier" fontsize=10 style="filled" shape=record fillcolor="#ECEFF1" color="#455A64"]
    edge [fontname="Helvetica" fontsize=9]

    bucket [label="{camu-data/|S3 Bucket}" fillcolor="#CFD8DC" shape=folder]

    meta [label="{_meta/topics/|orders.json\nevents.json}" fillcolor="#E8F4FD"]
    coord [label="{_coordination/|leader.json\ninstances/n1.json\ninstances/n2.json\ninstances/n3.json\nassignments/orders.json\nisr/orders/0.json\nisr/orders/1.json\ngroups/my-group/offsets.json}" fillcolor="#F3E5F5"]

    topic [label="{orders/|partition 0..3}" fillcolor="#FFF9C4"]

    p0 [label="{orders/0/|index.json\n0-1.segment\n5-1.segment\n10-2.segment}" fillcolor="#E8F5E9"]
    p1 [label="{orders/1/|index.json\n0-1.segment\n8-1.segment}" fillcolor="#E8F5E9"]

    index_detail [label="index.json\n\nsegments: [{base,end,epoch,key}...]\nepoch_history: [{epoch,start}...]\nhigh_watermark: 15" fillcolor="#FFFDE7" fontsize=9 shape=note]

    segment_detail [label="segment binary format\n\n[4B magic: 0x43414D55]\n[1B version] [1B compression]\n[compressed payload:]\n  [8B offset][8B timestamp]\n  [4B key_len][key]\n  [4B val_len][val]\n  [headers...] repeated" fillcolor="#FFFDE7" fontsize=9 shape=note]

    bucket -> meta
    bucket -> coord
    bucket -> topic
    topic -> p0
    topic -> p1
    p0 -> index_detail [style=dashed label="index.json structure"]
    p0 -> segment_detail [style=dashed label="segment format"]
}
